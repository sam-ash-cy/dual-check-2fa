# Secrets only. Put this file in the plugin folder or set the same variables in the server environment / wp-config.php.
# All other options: Settings → WP 2FA in wp-admin.

# Symfony Mailer DSN (contains credentials).
# WP2FA_MAILER_DSN=smtp://user:pass@mail.example.com:587

# Optional: stable HMAC key for one-time codes when multiple app servers must match.
# WP2FA_SECRET=
