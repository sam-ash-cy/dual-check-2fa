{
	"name": "sa/wp-dual-check",
	"description": "WP Dual Check — email second step after password (WordPress plugin).",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.2",
		"symfony/event-dispatcher": "^7.0",
		"symfony/amazon-mailer": "^7.2",
		"symfony/google-mailer": "^7.2",
		"symfony/http-client": "^7.2",
		"symfony/mailer": "^7.2",
		"symfony/mailgun-mailer": "^7.2",
		"symfony/mime": "^7.2",
		"symfony/postmark-mailer": "^7.2",
		"symfony/sendgrid-mailer": "^7.2",
		"vlucas/phpdotenv": "^5.6"
	},
	"autoload": {
		"psr-4": {
			"WPDualCheck\\": "includes/"
		}
	},
	"config": {
		"sort-packages": true
	}
}
