# Secrets only. Prefer WP_DUAL_CHECK_*; WP2FA_* still works if unset.
# Other options: WP Dual Check menu in wp-admin.

# Gmail (use an App Password, not your normal password): 16 chars only, no @ in the password.
# Port 465 (SSL):  WP_DUAL_CHECK_MAILER_DSN=smtps://YOUR_EMAIL@gmail.com:YOUR_APP_PASSWORD@smtp.gmail.com:465
# Port 587 (TLS):  WP_DUAL_CHECK_MAILER_DSN=smtp://YOUR_EMAIL@gmail.com:YOUR_APP_PASSWORD@smtp.gmail.com:587
# WP_DUAL_CHECK_SECRET=
